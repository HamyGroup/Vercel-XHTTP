{
  "version": 2,
  "name": "vercel-xhttp-relay",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "trailingSlash": false,
  "functions": {
    "api/index.js": { // یا api/index.ts اگر از TypeScript استفاده می‌کنید
      "memory": 1024 // مقدار حافظه بر حسب مگابایت (MB)
    }
  }
}
